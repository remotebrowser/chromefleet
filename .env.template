# Container image to use for Chromium instances
CONTAINER_IMAGE=ghcr.io/remotebrowser/chromium-live

# Podman remote socket (e.g. unix:///run/podman.sock). Leave unset to use local Podman.
CONTAINER_HOST=

# Residential proxy credentials (both required to enable proxy support)
MASSIVE_PROXY_USERNAME=
MASSIVE_PROXY_PASSWORD=

# Git revision shown in /health (set automatically in CI/CD)
GIT_REV=

# Server port
PORT=8300
